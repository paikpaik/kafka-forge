{
  "title": "kafka-forge",
  "uid": "kafka-forge",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Produce rate (msg/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kafka_forge_produced_total[1m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Consume rate (msg/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kafka_forge_consumed_total[1m])) by (topic, group)",
          "legendFormat": "{{topic}} / {{group}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Consumer lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "kafka_forge_consumer_lag",
          "legendFormat": "{{topic}} / partition {{partition}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error rate (errors/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kafka_forge_consume_errors_total[1m])) by (topic, group)",
          "legendFormat": "{{topic}} / {{group}}"
        },
        {
          "expr": "sum(rate(kafka_forge_produce_errors_total[1m])) by (topic)",
          "legendFormat": "produce {{topic}}"
        }
      ]
    }
  ]
}
